						{"command": "EXPLORE_RUINS", "argument": "1"},
						{"command": "GRANT_ITEM_FROM_POOL", "argument": "1"}
					]
				},
				{
					"weight": 0.10,
					"description":"%PERSON_NAME gains a rare item",
					"effects": [
						{"command": "EXPLORE_RUINS", "argument": "1"},
						{"command": "GRANT_ITEM_FROM_POOL", "argument": "2"}
					]
				},
				{
					"weight": 0.05,
					"description":"%PERSON_NAME gains an artefact level item",
					"effects": [
						{"command": "EXPLORE_RUINS", "argument": "1"},
						{"command": "GRANT_ITEM_FROM_POOL", "argument": "3"}
					]
				}
			]
		}
	]
